# Symlinked to ~/.zshrc by bootstrap.sh — edit here, changes show up in git.

eval "$(/opt/homebrew/bin/brew shellenv)"

# --------------------------------------------------------------------------
# oh-my-zsh
# --------------------------------------------------------------------------
export ZSH=$HOME/.oh-my-zsh
ZSH_THEME="morley-new"
plugins=(git)
source $ZSH/oh-my-zsh.sh

# git status in the prompt (used by the morley-new theme)
source ~/.zsh/git-prompt.zsh

# --------------------------------------------------------------------------
# nvm + auto-switch to the version in .nvmrc on cd
# --------------------------------------------------------------------------
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

autoload -U add-zsh-hook
load-nvmrc() {
	local nvmrc_path="$(nvm_find_nvmrc)"
	if [ -n "$nvmrc_path" ]; then
		local nvmrc_node_version=$(nvm version "$(cat "${nvmrc_path}")")
		if [ "$nvmrc_node_version" = "N/A" ]; then
			nvm install
		elif [ "$nvmrc_node_version" != "$(nvm version)" ]; then
			nvm use
		fi
	fi
}
add-zsh-hook chpwd load-nvmrc
load-nvmrc

# --------------------------------------------------------------------------
# Aliases & functions
# --------------------------------------------------------------------------
alias copy='pbcopy'
alias resource='source ~/.zshrc'
alias maindiff="git diff main -w"
alias f="rg -g '!src/locale'"

notify() {
	osascript -e 'display notification "Done" with title "Command complete"' \
		&& say done
}

# --------------------------------------------------------------------------
# Environment
# --------------------------------------------------------------------------
export RIPGREP_CONFIG_PATH="${HOME}/.ripgreprc"
export GPG_TTY=$(tty)
export CLAUDE_CODE_NO_FLICKER=1

# --------------------------------------------------------------------------
# PATH
# --------------------------------------------------------------------------
export PATH="/Applications/Postgres.app/Contents/Versions/18/bin:/usr/local/go/bin:${PATH}"
export PATH="$HOME/.yarn/bin:$PATH"
export PATH="$HOME/.local/share/solana/install/active_release/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
*":$PNPM_HOME:"*) ;;
*) export PATH="$PNPM_HOME:$PATH" ;;
esac

# --------------------------------------------------------------------------
# History & misc
# --------------------------------------------------------------------------
# Only write history when a shell exits, and don't share across live shells
unsetopt inc_append_history
unsetopt share_history

eval "$(mcfly init zsh)"
